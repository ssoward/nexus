# Secrets — never commit
.env

# TLS certificates
certs/

# Python
*.pyc
__pycache__/
.pytest_cache/
.venv/
*.egg-info/

# Database
*.db
*.db-wal
*.db-shm

# Session recovery snapshot
recovery.json

# Node / frontend
node_modules/
dist/

# Live-served static copy of frontend/dist (regenerated on every deploy)
static/

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# SwiftPM build artifacts
macos/Nexus/.build/

# Machine-specific tool paths generated by macos/install.sh (template is tracked)
scripts/nexus-paths.sh

# Backend runtime log (created when uvicorn is launched with nohup)
backend/uvicorn.log

# Test coverage artifacts
coverage/
**/coverage/
.coverage
