# Copy this to .env and fill in all values before running
# NEVER commit .env to version control

# --- REQUIRED SECRETS (generate with: openssl rand -hex 32) ---
APP_SECRET=replace_with_64_char_hex_string_openssl_rand_hex_32
JWT_SECRET=replace_with_64_char_hex_string_openssl_rand_hex_32
CRYPTO_SALT=replace_with_32_char_hex_string_openssl_rand_hex_16

# --- Optional: Email OTP (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM="Nexus <your-email@example.com>"

# --- Optional: Inject into Claude Code containers at exec time ---
# ANTHROPIC_API_KEY=sk-ant-...
