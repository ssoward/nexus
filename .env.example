# Copy this to .env and fill in all values before running
# NEVER commit .env to version control

# --- REQUIRED SECRETS (generate with: openssl rand -hex 32) ---
APP_SECRET=replace_with_64_char_hex_string_openssl_rand_hex_32
JWT_SECRET=replace_with_64_char_hex_string_openssl_rand_hex_32
CRYPTO_SALT=replace_with_32_char_hex_string_openssl_rand_hex_16

# --- Optional: Email OTP (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM="Nexus <your-email@example.com>"

# --- Optional: Inject into Claude Code containers at exec time ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Caddy host port override ---
# On hosts that can't reliably bind privileged ports (macOS + colima),
# expose Caddy on a high port and front it with `tailscale serve`:
#   CADDY_HOST_PORT=8443
#   tailscale serve --tcp=443 tcp://localhost:8443
# Defaults to 443 on hosts where privileged binding works (e.g. Linux + native Docker).
# CADDY_HOST_PORT=443
